# Docker 公共版前端运行时配置
# FRONT_API_BASE 通常留空，前端会自动走同源代理。
# 普通用户不需要在页面里看到或填写 API Base。
FRONT_API_BASE=

# 这里必须和 docker/auth.local.json 里的某一个后端 key 保持一致。
# 前端会自动带上这个后端鉴权 key。
FRONT_X_API_KEY=replace-with-your-backend-key

# 前端默认 OCR provider。
# 当前主线默认建议使用 paddle，也可以改成 mineru。
FRONT_OCR_PROVIDER=paddle

# 可选的 OCR / 模型默认配置。
# 如果希望最终用户在浏览器里自己填写 OCR / 模型配置，就保持为空。
FRONT_PADDLE_TOKEN=
FRONT_MINERU_TOKEN=
FRONT_MODEL_API_KEY=
FRONT_MODEL=deepseek-v4-flash
FRONT_BASE_URL=https://api.deepseek.com/v1
